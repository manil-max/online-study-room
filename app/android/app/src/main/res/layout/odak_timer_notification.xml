<?xml version="1.0" encoding="utf-8"?>
<!-- One UI bildirimi: sabit HH:MM:SS ve sağda tek eylem. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="4dp"
    android:paddingEnd="12dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/timer_notification_elapsed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:text="00:00:00"
        android:textColor="#FFFFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/timer_notification_action"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:background="@drawable/timer_notification_action_background"
        android:clickable="true"
        android:gravity="center"
        android:minWidth="88dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Durdur"
        android:textColor="#FFFFD8A6"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
