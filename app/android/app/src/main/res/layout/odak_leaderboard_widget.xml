<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/leaderboard_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_leaderboard_surface"
    android:contentDescription="@string/cd_leaderboard_widget"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/leaderboard_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_leaderboard_title"
        android:textColor="@color/widget_heading"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/leaderboard_widget_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_no_records"
        android:textColor="@color/widget_primary_text"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/leaderboard_widget_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_dash"
        android:textColor="@color/widget_secondary_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/leaderboard_widget_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_dash"
        android:textColor="@color/widget_secondary_text"
        android:textSize="12sp" />
</LinearLayout>
