<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/stats_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_stats_surface"
    android:contentDescription="@string/cd_stats_widget"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/stats_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_today"
        android:textColor="@color/widget_heading"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/stats_widget_today"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_minutes_zero"
        android:textColor="@color/widget_primary_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/stats_goal_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/stats_widget_week"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_week_preview"
        android:textColor="@color/widget_secondary_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/stats_widget_streak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_streak_preview"
        android:textColor="@color/widget_accent"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
