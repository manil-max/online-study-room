<?xml version="1.0" encoding="utf-8"?>
<!-- WP-76: Bildirim genişletildiğinde görünen native canlı kontrol paneli.
     Zaman Android Chronometer ile akar; eylemler doğrudan foreground service'e
     gider, Flutter motoru ya da uygulama resume'u gerekmez. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/notif_panel_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#DDE8FF"
        android:textSize="14sp" />

    <Chronometer
        android:id="@+id/notif_panel_elapsed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif-medium"
        android:text="00:00:00"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notif_panel_primary_action"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/timer_pill_bg"
            android:gravity="center"
            android:minWidth="104dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFD8A6"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_panel_stop_action"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/timer_pill_bg"
            android:gravity="center"
            android:minWidth="104dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
