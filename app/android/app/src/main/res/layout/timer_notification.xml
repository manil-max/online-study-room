<?xml version="1.0" encoding="utf-8"?>
<!-- WP-42/51: Sayaç bildiriminin özel görünümü. Standart bildirimde "boş kutu"
     yerine kronometre modundaki gerçek durak-saati gibi büyük, ortalanmış rakamlar
     gösterilir. Not: Android 12+ standart bildirim başlığındaki uygulama adını
     (Odak Kampı Beta) sistem çizer; özel görünümle bile kaldırılamaz. Uygulama adı
     olmayan yüzen kapsül (referans foto) OEM "canlı bildirim" / Android 16 Live
     Update yoludur — ayrı iş paketi. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <Chronometer
        android:id="@+id/notif_timer_elapsed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="start|center_vertical"
        android:text="00:00:00"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notif_timer_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="#26FFFFFF"
        android:gravity="center"
        android:minWidth="96dp"
        android:minHeight="44dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="Durdur"
        android:textColor="#FFD8A6"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
