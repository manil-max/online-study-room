<?xml version="1.0" encoding="utf-8"?>
<!-- WP-206: Samsung One UI'da doğrulanan tek satır sayaç: solda HH:MM:SS,
     sağda doğrudan Başlat/Durdur. Sistem aksiyonları kullanılmaz; One UI bunları
     ikinci satırda Break/Stop olarak çizdiği için ürün tasarımını bozuyordu. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingTop="6dp"
    android:paddingEnd="8dp"
    android:paddingBottom="6dp">

    <Chronometer
        android:id="@+id/notif_timer_elapsed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:gravity="start|center_vertical"
        android:maxLines="1"
        android:text="00:00:00"
        android:textColor="#FFFFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notif_timer_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/timer_pill_bg"
        android:gravity="center"
        android:minWidth="84dp"
        android:minHeight="44dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="Durdur"
        android:textColor="#FFFFD8A6"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
