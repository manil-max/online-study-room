<?xml version="1.0" encoding="utf-8"?>
<!-- WP-134: 1×1 hücre — üstte HH:MM:SS Chronometer, altta mini Başlat/Durdur.
     Chronometer her boyutta görünür (compact GONE yok). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timer_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151A18"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="6dp">

    <Chronometer
        android:id="@+id/timer_widget_elapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:text="00:00:00"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/timer_widget_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/timer_pill_bg"
        android:gravity="center"
        android:minHeight="32dp"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="@string/action_start"
        android:textColor="#FFD8A6"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
