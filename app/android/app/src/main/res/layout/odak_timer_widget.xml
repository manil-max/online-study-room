<?xml version="1.0" encoding="utf-8"?>
<!-- Sade sayaç widget'ı: yalnız akan saat + tek Başlat/Durdur düğmesi. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timer_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#151A18"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="14dp">

    <Chronometer
        android:id="@+id/timer_widget_elapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="00:00:00"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/timer_widget_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/timer_pill_bg"
        android:gravity="center"
        android:minHeight="44dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/action_start"
        android:textColor="#FFD8A6"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
