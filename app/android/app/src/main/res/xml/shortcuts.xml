    <shortcut
        android:shortcutId="samsung_routine_stop_timer"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_stop_timer_short"
        android:shortcutLongLabel="@string/shortcut_stop_timer_long">
        <intent
            android:action="com.manilmax.online_study_room.STOP_TIMER"
            android:targetPackage="com.manilmax.online_study_room"
            android:targetClass="com.manilmax.online_study_room.MainActivity" />
